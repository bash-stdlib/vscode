{
  "name": "bash-stdlib",
  "displayName": "bash-stdlib",
  "description": "Code completion for the bash stdlib library.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:shellscript"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Bash STDLIB",
      "properties": {
        "bash-stdlib.documentationLanguage": {
          "type": "string",
          "default": "en",
          "enum": [
            "en"
          ],
          "enumDescriptions": [
            "English documentation"
          ],
          "description": "The language code for the documentation."
        },
        "bash-stdlib.debug": {
          "type": "boolean",
          "default": false,
          "description": "Enable debug logging for completion provider activity in the debug console."
        },
        "bash-stdlib.linter.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable the external linter for shell files."
        },
        "bash-stdlib.linter.executablePath": {
          "type": "string",
          "default": "",
          "description": "The path to the stdlib linter script (main.py)."
        },
        "bash-stdlib.linter.pythonPath": {
          "type": "string",
          "default": "python3",
          "description": "The path to the python binary to use for running the linter."
        },
        "bash-stdlib.linter.interval": {
          "type": "number",
          "default": 500,
          "description": "The interval (in milliseconds) at which to run the linter while editing."
        },
        "bash-stdlib.linter.ignoredCodes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "A list of linter error codes to ignore."
        },
        "bash-stdlib.whiteListedNamespaces": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Extra namespaces to inject. Used for development purposes."
        }
      }
    },
    "commands": [
      {
        "command": "bash-stdlib.helloWorld",
        "title": "Hello World"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && tsc-alias && rsync -am --include='*/' --include='assets/***' --exclude='*' src/ out/",
    "ci": "xvfb-run npm test",
    "watch": "concurrently --prefix none \"tsc-alias -w\" \"tsc -w\" ",
    "pretest": "npm run compile && npm run lint",
    "pre_commit_prettier": "npx prettier --write",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/sinon": "^21.0.1",
    "@types/vscode": "^1.118.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "concurrently": "^10.0.0",
    "eslint": "^9.39.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.8.3",
    "sinon": "^22.0.0",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
